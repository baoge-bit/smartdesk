{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlphaDesk",
  "version": "1.0.0",
  "identifier": "com.alphadesk.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AlphaDesk · 阿尔法工作台",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/alphadesk-engine"
    ],
    "shortDescription": "AI-powered multi-market stock research workspace",
    "longDescription": "AlphaDesk transforms LLM-powered stock analysis into a polished desktop research workspace for A-shares, Hong Kong, and US markets.",
    "category": "Finance",
    "copyright": "Copyright © 2026 AlphaDesk",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/baoge-bit/smartdesk/releases/latest/download/latest.json"
      ],
      "pubkey": "dW5zZXR0ZWQ="
    }
  }
}